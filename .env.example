# ==============================================================================
# ESENCIA - ARCHIVO DE CONFIGURACIÓN DE EJEMPLO (.env.example)
# Copia este archivo como .env y rellena los valores reales.
# ==============================================================================

# === Configuración del Proyecto ===
PROJECT_NAME=esencia
DJANGO_SETTINGS_MODULE=config.settings
SECRET_KEY_DJANGO=tu_django_secret_key_aqui_aleatoria
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.esencia.local
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# === Seguridad y JWT ===
JWT_ACCESS_COOKIE_NAME=esencia_access_token
JWT_ALGORITHM=HS256
JWT_SIGNING_KEY=tu_jwt_signing_key_de_al_menos_32_caracteres
JWT_ACCESS_TOKEN_LIFETIME_SECONDS=3600
JWT_COOKIE_SECURE=0
JWT_COOKIE_SAMESITE=Lax

# === Base de Datos (PostgreSQL) ===
POSTGRES_DB=esencia_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# === Inteligencia Artificial (OpenAI) ===
# Consigue tu clave en: https://platform.openai.com/
OPENAI_API_KEY=tu_openai_api_key_aqui

# === Pasarela de Pagos (Stripe) ===
# Consigue tus claves en: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLIC_KEY=tu_stripe_public_key_aqui
STRIPE_SECRET_KEY=tu_stripe_secret_key_aqui
STRIPE_WEBHOOK_SECRET=tu_stripe_webhook_secret_aqui

# === Correo Electrónico (SMTP) ===
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_contraseña_de_aplicacion_aqui

# === Redis y Tareas en Segundo Plano ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# === Frontend ===
FRONTEND_PORT=5173
VITE_API_URL=http://127.0.0.1:8000/api

# === Calidad de Código (SonarCloud) ===
# No es necesario en el .env local si usas GitHub Secrets, pero se deja como referencia.
SONAR_TOKEN=tu_sonar_token_aqui
SONAR_PROJECT_KEY=celiasuaco_esencia
SONAR_ORGANIZATION=celiasuaco